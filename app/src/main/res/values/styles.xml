<!-- res/values/styles.xml -->
<style name="AppTheme" parent="android:Theme.DeviceDefault.NoActionBar">
    <!-- 1. حذف ActionBar/TitleBar (با parent "NoActionBar" انجام شده) -->

    <!-- 2. StatusBar شفاف -->
    <item name="android:windowTranslucentStatus">true</item>
    <item name="android:statusBarColor">@android:color/transparent</item>

    <!-- 3. NavigationBar همرنگ پس‌زمینه (مات) -->
    <item name="android:navigationBarColor">@color/background</item>

    <!-- 4. رنگ کلی پس‌زمینه -->
    <item name="android:windowBackground">@color/background</item>

    <!-- 5. رنگ متن پیش‌فرض -->
    <item name="android:textColor">@color/on_background</item>

    <!-- 6. اجازه رفتن محتوا زیر StatusBar -->
    <item name="android:fitsSystemWindows">false</item>

    <!-- 7. تنظیم رنگ آیکون‌های StatusBar برای اندروید 6+ -->
    <item name="android:windowLightStatusBar">true</item>
</style>
